---
interface Props {
  icon: string;
}

const { icon } = Astro.props;

const iconLabelMap: Record<string, string> = {
  spotify: 'SP',
  'apple-music': 'AM',
  'amazon-music': 'AZ',
  link: 'LN',
};

const label = iconLabelMap[icon] ?? icon.slice(0, 2).toUpperCase();
---

<span
  aria-hidden="true"
  class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-cyan-300/20 bg-cyan-300/10 text-[0.7rem] font-semibold uppercase tracking-[0.22em] text-cyan-50"
>
  {label}
</span>
