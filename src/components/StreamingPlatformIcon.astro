---
import { Icon } from 'astro-icon/components';

interface Props {
  icon: string;
}

const { icon } = Astro.props;
const iconName = icon.trim().length > 0 ? icon : 'lucide:link';
---

<span
  aria-hidden="true"
  class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-cyan-300/20 bg-cyan-300/10 text-cyan-50"
>
  <Icon name={iconName} class="h-5 w-5" />
</span>
