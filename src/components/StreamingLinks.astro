---
import type { ResolvedPlatformLink } from '../lib/site-config';

import StreamingPlatformIcon from './StreamingPlatformIcon.astro';

interface Props {
  links: ResolvedPlatformLink[];
}

const { links } = Astro.props;
---

<ul class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
  {
    links.map((link) => (
      <li>
        <a
          href={link.url}
          target="_blank"
          rel="noreferrer"
          class="group flex items-center gap-4 rounded-[1.4rem] border border-white/10 bg-slate-950/72 px-4 py-3 shadow-[0_18px_48px_rgba(2,6,23,0.2)] transition duration-200 hover:border-cyan-300/30 hover:bg-slate-900/85"
        >
          <StreamingPlatformIcon icon={link.icon} />
          <div class="space-y-1">
            <p class="text-[0.68rem] font-medium uppercase tracking-[0.28em] text-cyan-200/68">
              Streaming platform
            </p>
            <p class="text-base font-medium tracking-[-0.02em] text-slate-100 transition group-hover:text-white">
              {link.title}
            </p>
          </div>
        </a>
      </li>
    ))
  }
</ul>
