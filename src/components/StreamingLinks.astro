---
import type { ResolvedPlatformLink } from '../lib/site-config';

import StreamingPlatformIcon from './StreamingPlatformIcon.astro';

interface Props {
  links: ResolvedPlatformLink[];
}

const { links } = Astro.props;
---

<ul class="flex flex-wrap gap-3">
  {
    links.map((link) => (
      <li>
        <a
          href={link.url}
          target="_blank"
          rel="noreferrer"
          aria-label={link.title}
          title={link.title}
          class="group inline-flex h-14 w-14 items-center justify-center rounded-2xl border border-white/10 bg-slate-950/72 shadow-[0_18px_48px_rgba(2,6,23,0.2)] transition duration-200 hover:border-cyan-300/30 hover:bg-slate-900/85"
        >
          <StreamingPlatformIcon icon={link.icon} />
          <span class="sr-only">{link.title}</span>
        </a>
      </li>
    ))
  }
</ul>
