---
import type { ResolvedPlatformLink } from '../lib/site-config';

import StreamingLinks from '../components/StreamingLinks.astro';
import { withBasePath } from '../lib/paths';
import { siteConfig } from '../lib/site-config';
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  summary: string;
  heroImage: string;
  lyrics: string;
  streamingLinks: ResolvedPlatformLink[];
}

const { title, summary, heroImage, lyrics, streamingLinks } = Astro.props;
const heroBackground = `linear-gradient(180deg, rgba(5, 8, 22, 0.14) 0%, rgba(5, 8, 22, 0.9) 100%), url(${withBasePath(heroImage)})`;
---

<BaseLayout title={`${title} | ${siteConfig.author}`} description={summary}>
  <section class="relative isolate overflow-hidden border-b border-white/10">
    <div
      class="absolute inset-0 -z-10 bg-cover bg-center"
      style={`background-image: ${heroBackground};`}
    >
    </div>
    <div
      class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_top,rgba(34,211,238,0.2),transparent_40%)]"
    >
    </div>
    <div
      class="absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-t from-slate-950 to-transparent"
    >
    </div>
    <div
      class="mx-auto flex min-h-[24rem] max-w-6xl flex-col justify-end gap-6 px-6 py-16 sm:px-8 lg:py-24"
    >
      <div class="space-y-3">
        <p
          class="text-[0.68rem] font-medium uppercase tracking-[0.32em] text-cyan-200/72"
        >
          {siteConfig.author} · {siteConfig.albumTitle}
        </p>
        <h1
          class="max-w-4xl text-5xl font-medium leading-[0.9] tracking-[-0.05em] text-balance text-slate-50 sm:text-7xl"
        >
          {title}
        </h1>
        <p class="max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
          {summary}
        </p>
      </div>
    </div>
  </section>

  <section
    class="mx-auto grid max-w-6xl gap-10 px-6 py-10 sm:px-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.35fr)] lg:py-16"
  >
    <section class="space-y-4 lg:col-span-2">
      <p
        class="text-[0.68rem] font-medium uppercase tracking-[0.32em] text-cyan-200/70"
      >
        Listen on
      </p>
      <StreamingLinks links={streamingLinks} />
    </section>

    <aside
      class="rounded-[1.75rem] border border-white/10 bg-slate-950/70 p-6 shadow-[0_24px_70px_rgba(2,6,23,0.34)] backdrop-blur-xl sm:p-8"
    >
      <p
        class="text-[0.68rem] font-medium uppercase tracking-[0.32em] text-cyan-200/70"
      >
        Lyrics
      </p>
      <div class="mt-5 whitespace-pre-wrap text-base leading-8 text-slate-200">
        {lyrics}
      </div>
    </aside>

    <section
      class="rounded-[1.75rem] border border-white/10 bg-slate-950/70 p-6 shadow-[0_24px_70px_rgba(2,6,23,0.34)] backdrop-blur-xl sm:p-8"
    >
      <p
        class="text-[0.68rem] font-medium uppercase tracking-[0.32em] text-cyan-200/70"
      >
        Song explanation
      </p>
      <div class="song-prose mt-5">
        <slot />
      </div>
    </section>
  </section>
</BaseLayout>
